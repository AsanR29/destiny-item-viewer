mixin ShitLine(size, width, height)
    svg(viewBox=`0 0 ${width} ${height}` xmlns="http://www.w3.org/2000/svg" stroke-width="1")
        -
            let counter = 1;
            // let whites = ColorSpectrum(["FF","FF","FF","FF"],3);
            //let odds = [1,1,2,4,4,4,4,3,3,3,2,1,1,1,1,1];
            let whites = ["#FFFFFF11","#FFFFFF55","#FFFFFFBB"];
            let odds = [1,1,1];
            let x_max = Math.floor(width/size)*2;
            let y_max = Math.floor(height/size);
        while counter < x_max
            +TigerLine([counter*20,0],[size,size],x_max-counter,whites,odds)
            -
                ++counter;
        -
            counter = 0;
        while counter < y_max
            +TigerLine([0,counter*20],[size,size],x_max,whites,odds)
            //-
            +TigerLine([0,counter*20],[size,-1*size],x_max,whites,odds)
            //-
            +TigerLine([0,counter*20],[4*size,0],x_max,whites,odds)
            +TigerLine([-10,10+counter*20],[4*size,0],x_max,whites,odds)
            -
                ++counter;