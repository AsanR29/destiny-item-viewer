-
    //{x:,y:}
    const pi_ratio = Math.PI/180;

    const one_line = [{x:-0.5,y:-0.5,},{x:0.5,y:0.5}];
    const simple_triangle = [{x:-0.5,y:0.433},{x:0,y:-0.433},{x:0.5,y:0.433}]; //[{x:0,y:0.866},{x:0.5,y:0},{x:1,y:0.866}];
    const simple_quadrilateral = [{x:-0.7,y:-0.79},{x:0,y:-0.2},{x:0.7,y:-0.2},{x:-0.5,y:0.6}];
    const wall_paper_line = [{x:-0.2,y:-1},{x:-0.1,y:-0.8},{x:-0.1,y:0.8},{x:0.1,y:1},{x:0.2,y:1},{x:0.1,y:0.8},{x:0.1,y:-0.8},{x:-0.1,y:-1}];
    const invert_wall_paper_line = [{x:0.2,y:-1},{x:0.1,y:-0.8},{x:0.1,y:0.8},{x:-0.1,y:1},{x:-0.2,y:1},{x:-0.1,y:0.8},{x:-0.1,y:-0.8},{x:0.1,y:-1}];
    const diamond_like_corner = [{x:0.3,y:1},{x:0.6,y:0.8},{x:0.65,y:0.55},{x:0.8,y:0.4},{x:1,y:0.3},{x:1,y:1}];
    //obligatory. not mine
    function getBaseLog(x, y) {
        return Math.log(y) / Math.log(x);
    }
    //
    function DrawShape(coord_set,size,x_off,y_off,angle)
    {
        let real_angle = pi_ratio * angle;
        let final_coords = [];
        let new_x, new_y;
        for(let i = 0; i < coord_set.length; i++)
        {
            old_x = coord_set[i].x * size;
            old_y = coord_set[i].y * size;

            //- Rotation matrix I suppose ?
            new_x = old_x*Math.cos(real_angle) - old_y*Math.sin(real_angle) + x_off;
            new_y = old_x*Math.sin(real_angle) + old_y*Math.cos(real_angle) + y_off;
            final_coords.push({x: new_x,y: new_y});
        }
        let points_text = "";
        for(let i = 0; i < final_coords.length; i++)
        {
            points_text += final_coords[i].x.toString() + ',' + final_coords[i].y.toString() + ' ';
        }
        return points_text;
    }
    function MoveDiagonally(x,y,size,angle){
        let real_angle = pi_ratio * angle;
        let new_x, new_y;

        new_x = size*Math.cos(real_angle) - size*Math.sin(real_angle) + x;
        new_y = size*Math.sin(real_angle) + size*Math.cos(real_angle) + y;

        return {'x':new_x,'y':new_y};
    }
    function ApproachLimit(input,increment,limit){
        input += increment;
        if(input > limit){ input = limit; }
        return input;
    }
    function PopulateLine(LinesA,x_max,y_max){
        let select_line, mine_pos;
        for(let i = 0; i < 50; i++){
            select_line = Math.floor(Math.random()*x_max);
            mine_pos = Math.floor(Math.random()*y_max);
            if( !(select_line in LinesA)){
                LinesA[select_line] = [];
            }
            LinesA[select_line].push(mine_pos);
        }
        return LinesA;
    }
    function compareNumbers(a, b) {
        return a - b;
    }
    function PointToText(point){
        let text = `${point[0]},${point[1]} `;
        return text;
    }
    function PointSum(a,b){
        let c = [a[0]+b[0],a[1]+b[1]];
        return c;
    }
    function add(a, b){
        return a + b;
    }
    function RandomOutcome(outcomes,weights){
        if(outcomes.length != weights.length){ return -1; }


        let sum = weights.reduce(add,0);
        let pos = Math.floor(Math.random()*sum);
        //console.log("pos = ",pos);
        let running_total = 0;
        let i;
        for(i = 0; i < weights.length; ++i){
            running_total += weights[i];
            if(running_total > pos)
                break;
        }
        if(i > outcomes.length){ return -1; }
        // else
        return outcomes[i];
    }
    function ColorSpectrum(color_code,pos){
        let spectrum = ["00","11","22","33","44","55","66","77","88","99","AA","BB","CC","DD","EE","FF"];
        let sub_color;
        let result = [];
        for(let i = 0; i < 16; i++){
            color_code[pos] = spectrum[i];
            sub_color = color_code.reduce(add,"#");
            result.push(sub_color);
        }
        return result;
    }

