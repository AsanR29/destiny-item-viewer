extends ./destiny_layout

block content
    include ../../src/svg_mixins.pug
    body(class="bg-grey-100 t-grey-900")
        main(class="main-center max-w-80")
            section(class="bg-blue-600 t-black")
                div(class="main-center max-w-80 pad-y-5 text-center")
                    h1(class="h-2-5") Error: 503
                    p(class="p-1-7") Most likely, the bungie API is down! Check 
                        a(class="t-cyan-400" href="https://help.bungie.net/hc/en-us/articles/360049199271-Destiny-Server-and-Update-Status") here